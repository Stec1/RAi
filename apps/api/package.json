{
  "name": "@rai/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm --filter @rai/shared build && DATABASE_URL=${DATABASE_URL:-postgres://placeholder} prisma generate",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "pretypecheck": "pnpm --filter @rai/shared build && DATABASE_URL=${DATABASE_URL:-postgres://placeholder} prisma generate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@rai/shared": "workspace:*",
    "better-auth": "^1.6.5",
    "fastify": "^4.28.1",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prisma": "^7.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "config": "prisma.config.ts"
  }
}
