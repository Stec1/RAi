# RAi - Environment Variables
# Copy to .env.local and fill in values.
# See docs/architecture.md for naming conventions.

# === API ===
# PORT=3001

# === Database ===
# DATABASE_URL=postgresql://user:password@localhost:5432/rai
DATABASE_URL=

# === Redis ===
# REDIS_URL=redis://localhost:6379
REDIS_URL=

# === Auth ===
# BETTER_AUTH_SECRET — 32+ char random string (use `openssl rand -base64 32`)
# BETTER_AUTH_URL — API base URL (e.g. http://localhost:3001 or https://api.rai.app)
# WEB_URL — Web frontend origin (e.g. http://localhost:3000 or https://rai.app)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
WEB_URL=

# === Web (public) ===
# NEXT_PUBLIC_API_URL — Legacy/SSR fallback. The browser no longer hits the
# API directly; all `/api/*` calls are same-origin and proxied by Next.js
# (see API_PROXY_ORIGIN below). This var is only used in SSR contexts where
# `window` is unavailable. Safe to leave blank locally.
NEXT_PUBLIC_API_URL=

# === Web (server-side proxy) ===
# API_PROXY_ORIGIN — Origin the Next.js server forwards `/api/*` requests to.
# This makes browser fetches first-party on the web origin, sidestepping
# cross-site cookie blocking (Safari ITP, third-party cookie restrictions).
#
# Local dev:    http://localhost:3001  (default if unset)
# Vercel:       set to the Railway API URL, e.g.
#               API_PROXY_ORIGIN=https://raiapi-production.up.railway.app
#
# Railway (API) still needs WEB_URL set to the Vercel origin so Better Auth
# trusts the web frontend; the upstream API never sees the browser directly.
API_PROXY_ORIGIN=